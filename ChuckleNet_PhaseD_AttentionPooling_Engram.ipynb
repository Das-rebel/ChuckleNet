    "with torch.no_grad():\n",
    "    for vi in range(len(val)):\n",
    "        vs = val[vi]\n",
    "        va = load_audio_segment(vs)\n",
    "        pf = prosody_dict.get(f\"{vs['video_id']}_{vs['start']:.2f}\", np.zeros(55))\n",
    "        vx = torch.from_numpy(va[None, None]).to(device)\n",
    "        vp_t = torch.from_numpy(pf[None]).float().to(device)\n",
    "        logits = model(vx, vp_t)\n",
    "        prob = torch.softmax(logits, dim=1)[0, 1].cpu().item()\n",
    "        all_probs.append(prob)\n",
    "        all_labels.append(vs['label'])\n",
    "\n",
    "all_probs = np.array(all_probs)\n",
    "all_labels = np.array(all_labels)\n",
    "\n",
    "print(f\"\\n{'Threshold':>10} {'Precision':>10} {'Recall':>10} {'F1':>10} {'TP':>6} {'FP':>6} {'FN':>6}\")\n",
    "print('-' * 70)\n",
    "results = []\n",
    "for t in [0.30, 0.40, 0.50, 0.55, 0.60, 0.65, 0.70, 0.75, 0.80]:\n",
    "    preds = (all_probs >= t).astype(int)\n",
    "    tp = int(((preds == 1) & (all_labels == 1)).sum())\n",
    "    fp = int(((preds == 1) & (all_labels == 0)).sum())\n",
    "    fn = int(((preds == 0) & (all_labels == 1)).sum())\n",
    "    prec = tp / (tp+fp) if (tp+fp) > 0 else 0\n",
    "    rec  = tp / (tp+fn) if (tp+fn) > 0 else 0\n",
    "    f1   = 2*prec*rec/(prec+rec) if (prec+rec) > 0 else 0\n",
    "    print(f'{t:>10.2f} {prec:>10.4f} {rec:>10.4f} {f1:>10.4f} {tp:>6} {fp:>6} {fn:>6}')\n",
    "    results.append({'threshold': t, 'precision': prec, 'recall': rec, 'f1': f1})\n",
    "\n",
    "best = max(results, key=lambda r: r['f1'])\n",
    "print(f\"\\n✅ BEST: t={best['threshold']:.2f} F1={best['f1']:.4f} P={best['precision']:.4f} R={best['recall']:.4f}\")\n",
