    "# 8️⃣ Prosody feature extraction (per-segment, from raw audio)\n",
    "\n",
    "def extract_prosody(audio_path, start_sec, end_sec, sr=16000):\n",
    "    \"\"\"\n",
    "    Extract 52-dimensional prosody features for ToM signals.\n",
    "    Based on validated linguistics findings:\n",
    "      - Purandare 2006: pause >= 0.8s = strongest humor predictor\n",
    "      - Bachorowski 2001: F0 variability = Duchenne genuineness marker\n",
    "      - Incongruity: energy spikes, F0 jumps\n",
    "    \"\"\"\n",
    "    try:\n",
    "        y, _ = librosa.load(audio_path, sr=sr, mono=True,\n",
    "                           offset=max(0, start_sec - 0.1),\n",
    "                           duration=(end_sec - start_sec) + 0.2)\n",
    "    except:\n",
    "        y = np.zeros(int(5 * sr), dtype=np.float32)\n",
    "    \n",
    "    feats = []\n",
    "    \n",
    "    # 1. PAUSE features (ToM #1 — Purandare 2006) [7 features]\n",
    "    intervals = librosa.effects.split(y, top_db=30, frame_length=1024, hop_length=512)\n",
    "    if len(intervals) > 1:\n",
    "        pauses = [(intervals[i+1][0] - intervals[i][1]) / sr for i in range(len(intervals)-1)]\n",
    "        feats.extend([\n",
    "            max(pauses) if pauses else 0.0,           # pause_max\n",
    "            np.mean(pauses) if pauses else 0.0,       # pause_mean\n",
    "            sum(1 for p in pauses if p >= 0.8),         # long_pause_count\n",
    "            float(any(p >= 0.8 for p in pauses)),       # has_long_pause\n",
    "            sum(1 for p in pauses if p >= 1.5),         # very_long_pause_count\n",
    "            sum(p >= 0.8 for p in pauses) / max(len(pauses), 1),  # long_pause_density\n",
    "            sum(pauses)                                  # pause_total\n",
    "        ])\n",
    "    else:\n",
    "        feats.extend([0.0] * 7)\n",
    "    \n",
    "    # 2. F0 / PITCH features (Duchenne) [8 features]\n",
    "    try:\n",
    "        f0, voiced, _ = librosa.pyin(y, fmin=75, fmax=500, sr=sr,\n",
    "                                      frame_length=2048, hop_length=512)\n",
    "        f0_clean = f0[~np.isnan(f0)]\n",
    "        if len(f0_clean) > 5:\n",
    "            feats.extend([\n",
    "                float(np.mean(f0_clean)),                     # f0_mean\n",
    "                float(np.std(f0_clean)),                       # f0_std\n",
    "                float(np.max(f0_clean) - np.min(f0_clean)),   # f0_range\n",
    "                float(np.max(f0_clean)),                       # f0_max\n",
    "                float(np.std(f0_clean)) / max(np.mean(f0_clean), 1),  # f0_variability\n",
    "                float(np.mean(voiced[~np.isnan(f0)])),          # voiced_ratio\n",
    "                float(np.polyfit(range(len(f0_clean)), f0_clean, 1)[0]) if len(f0_clean) > 2 else 0.0,  # f0_slope\n",
    "                float(np.mean(np.abs(np.diff(f0_clean)))) if len(f0_clean) > 2 else 0.0  # f0_jump\n",
    "            ])\n",
    "        else:\n",
    "            feats.extend([0.0] * 8)\n",
    "    except:\n",
    "        feats.extend([0.0] * 8)\n",
    "    \n",
    "    # 3. ENERGY / RMS features (Incongruity) [6 features]\n",
    "    try:\n",
    "        rms = librosa.feature.rms(y=y, frame_length=2048, hop_length=512)[0]\n",
    "        threshold = np.mean(rms) + 2 * np.std(rms)\n",
    "        feats.extend([\n",
    "            float(np.mean(rms)),                             # rms_mean\n",
    "            float(np.std(rms)),                              # rms_std\n",
    "            float(np.max(rms) - np.min(rms)),                # rms_range\n",
    "            sum(1 for r in rms if r > threshold),            # energy_spike_count\n",
    "            float(np.max(np.abs(np.diff(rms)))) if len(rms) > 1 else 0.0,  # delta_rms_max\n",
    "            float(np.mean(rms[rms > threshold])) if sum(rms > threshold) > 0 else 0.0  # above_thresh_energy\n",
    "        ])\n",
    "    except:\n",
    "        feats.extend([0.0] * 6)\n",
    "    \n",
    "    # 4. SPECTRAL features (voice quality) [6 features]\n",
    "    try:\n",
    "        sc = librosa.feature.spectral_centroid(y=y, sr=sr)[0]\n",
    "        sb = librosa.feature.spectral_bandwidth(y=y, sr=sr)[0]\n",
    "        sr_feat = librosa.feature.spectral_rolloff(y=y, sr=sr)[0]\n",
    "        feats.extend([\n",
    "            float(np.mean(sc)),\n",
    "            float(np.std(sc)),\n",
    "            float(np.mean(sb)),\n",
    "            float(np.std(sb)),\n",
    "            float(np.mean(sr_feat)),\n",
    "            float(np.std(sr_feat))\n",
    "        ])\n",
    "    except:\n",
    "        feats.extend([0.0] * 6)\n",
    "    \n",
    "    # 5. MFCC features (13 standard + 13 delta = 26 features)\n",
    "    try:\n",
    "        mfccs = librosa.feature.mfcc(y=y, sr=sr, n_mfcc=13)\n",
    "        delta_mfccs = librosa.feature.delta(mfccs)\n",
    "        for i in range(13):\n",
    "            feats.extend([\n",
    "                float(np.mean(mfccs[i])),      # mfcc{i}_mean\n",
    "                float(np.mean(delta_mfccs[i]))  # delta_mfcc{i}_mean\n",
    "            ])\n",
    "    except:\n",
    "        feats.extend([0.0] * 26)\n",
    "    \n",
    "    # 6. SPEECH RATE proxy [2 features]\n",
    "    try:\n",
    "        zcr = librosa.feature.zero_crossing_rate(y=y, frame_length=1024, hop_length=512)[0]\n",
    "        feats.extend([\n",
    "            float(end_sec - start_sec),                           # utterance_duration\n",
    "            float(np.mean(zcr))                                   # zcr_mean\n",
    "        ])\n",
    "    except:\n",
    "        feats.extend([0.0] * 2)\n",
    "    \n",
    "    # Total: 7+8+6+6+26+2 = 55 features\n",
    "    return np.array(feats, dtype=np.float32)\n",
    "\n",
    "# Test\n",
    "test_feat = extract_prosody(train[0]['audio_path'], train[0]['start'], train[0]['end'])\n",
    "print(f'Prosody features: {len(test_feat)} dimensions')\n",
    "print(f'Feature groups: pause(7) + f0(8) + rms(6) + spectral(6) + mfcc(26) + speech(2) = 55')"
   ]
  },
