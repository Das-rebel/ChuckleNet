    "    print(f'Epoch {epoch:2d}/{EPOCHS} ({elapsed:.0f}s) | '\n",
    "          f'loss={train_loss:.4f} | Train F1={train_f1:.4f} | '\n",
    "          f'Val F1={val_f1:.4f} P={val_p:.4f} R={val_r:.4f}')\n",
    "    \n",
    "    history.append({'epoch': epoch, 'train_loss': train_loss, 'train_f1': train_f1,\n",
    "                     'val_f1': val_f1, 'val_p': val_p, 'val_r': val_r, 'time': elapsed})\n",
    "    \n",
    "    if val_f1 > best_val_f1:\n",
    "        best_val_f1 = val_f1\n",
    "        torch.save({\n",
    "            'epoch': epoch, \n",
    "            'model_state_dict': model.state_dict(),\n",
    "            'val_f1': val_f1,\n",
    "            'val_p': val_p,\n",
    "            'val_r': val_r,\n",
    "        }, f'{OUTPUT_DIR}/phaseD_best.pt')\n",
    "        print(f'  ✅ Saved best (Val F1={val_f1:.4f})')\n",
    "\n",
    "print(f'\\nBest Val F1: {best_val_f1:.4f}')"
