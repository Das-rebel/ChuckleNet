   "source": [
    "# 7️⃣ Build the full Phase D model\n",
    "\n",
    "from transformers import WavLMModel, Wav2Vec2FeatureExtractor\n",
    "\n",
    "device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n",
    "print('Loading WavLM...')\n",
    "wavlm_encoder = WavLMModel.from_pretrained('microsoft/wavlm-base-plus')\",
    "\n",
    "# ============================================================\n",
    "# PARTIAL UNFREEZE: last 6 transformer layers\n",
    "# ============================================================\n",
    "N_UNFREEZE = 6\n",
    "for param in wavlm_encoder.parameters():\n",
    "    param.requires_grad = False\n",
    "\n",
    "for layer in list(wavlm_encoder.encoder.layers)[-N_UNFREEZE:]:\n",
    "    for param in layer.parameters():\n",
    "        param.requires_grad = True\n",
    "\n",
    "feature_extractor = Wav2Vec2FeatureExtractor.from_pretrained('microsoft/wavlm-base-plus')\n",
    "\n",
    "class PhaseDModel(torch.nn.Module):\n",
    "    \"\"\"\n",
    "    Phase D: Redesigned audio laughter detector.\n",
    "    \n",
    "    Components (in order):\n",
    "      1. WavLM encoder (partial unfreeze, last 6 layers)\n",
    "      2. AttentionPooling or MLA (learns which frames matter)  \n",
    "      3. EngramModule (compression bottleneck, 768→128)\n",
    "      4. Prosody branch (pause/F0/RMS extracted from raw audio)\n",
    "      5. Optional CSA (compressed sparse attention)\n",
    "    \"\"\"\n",
    "    def __init__(self, encoder, use_csa=True, use_mla=False, engram_dim=128, \n",
    "                 prosody_dim=52, n_heads=4):\n",
    "        super().__init__()\n",
    "        self.encoder = encoder\n",
    "        self.use_csa = use_csa\n",
    "        self.use_mla = use_mla\n",
    "        \n",
    "        H = 768  # WavLM hidden dim\n",
    "        \n",
    "        # Audio pooling options\n",
    "        if use_mla:\n",
    "            self.audio_pool = MultiHeadLatentAttentionPooling(H, n_heads=n_heads)\n",
    "        elif use_csa:\n",
    "            self.audio_pool = CompressedSparseAttention(H, k_frames=50)\n",
    "        else:\n",
    "            self.audio_pool = AttentionPooling(H)\n",
    "        \n",
    "        # Engram compression bottleneck\n",
    "        self.engram = EngramModule(input_dim=H, bottleneck_dim=engram_dim)\n",
    "        \n",
    "        # Prosody feature projection\n",
    "        self.prosody_proj = torch.nn.Sequential(\n",
    "            torch.nn.Linear(prosody_dim, 64),\n",
    "            torch.nn.GELU(),\n",
    "            torch.nn.Dropout(0.1),\n",
    "            torch.nn.Linear(64, 64)\n",
    "        )\n",
    "        \n",
    "        # Total fused dim: audio(128) + prosody(64)\n",
    "        total_dim = engram_dim + 64\n",
    "        \n",
    "        # Classifier head\n",
    "        self.classifier = torch.nn.Sequential(\n",
    "            torch.nn.Linear(total_dim, 128),\n",
    "            torch.nn.LayerNorm(128),\n",
    "            torch.nn.GELU(),\n",
    "            torch.nn.Dropout(0.3),\n",
    "            torch.nn.Linear(128, 64),\n",
    "            torch.nn.LayerNorm(64),\n",
    "            torch.nn.GELU(),\n",
    "            torch.nn.Dropout(0.2),\n",
    "            torch.nn.Linear(64, 2)\n",
    "        )\n",
    "    \n",
    "    def forward(self, waveforms, prosody_feats=None, return_features=False):\n",
    "        \"\"\"\n",
    "        waveforms: (batch, 1, 80000) — 5 seconds of audio\n",
    "        prosody_feats: (batch, prosody_dim) — pre-extracted prosody features\n",
    "        \"\"\"\n",
    "        # 1. WavLM encoder\n",
    "        wav_list = [w.cpu().numpy().squeeze() for w in waveforms]\n",
    "        inputs = feature_extractor(wav_list, sampling_rate=SR, return_tensors='pt', padding=True)\",
    "        inputs = {k: v.to(waveforms.device) for k, v in inputs.items()}\n",
    "        \n",
    "        # Only compute encoder grads for unfrozen layers\n",
    "        with torch.set_grad_enabled(any(p.requires_grad for p in self.encoder.parameters())):\n",
    "            hidden = self.encoder(**inputs).last_hidden_state  # (batch, T, 768)\n",
    "        \n",
    "        # 2. Attention pooling\n",
    "        if self.use_mla:\n",
    "            pooled, attn_w = self.audio_pool(hidden)\n",
    "        elif self.use_csa:\n",
    "            pooled, attn_w, topk_idx = self.audio_pool(hidden)\n",
    "        else:\n",
    "            pooled, attn_w = self.audio_pool(hidden)\n",
    "        \n",
    "        # 3. Engram compression\n",
    "        engram_emb = self.engram(pooled)  # (batch, 128)\n",
    "        \n",
    "        # 4. Prosody features\n",
    "        if prosody_feats is not None:\n",
    "            prosody_emb = self.prosody_proj(prosody_feats)  # (batch, 64)\n",
    "            fused = torch.cat([engram_emb, prosody_emb], dim=1)  # (batch, 192)\n",
    "        else:\n",
    "            fused = engram_emb\n",
    "        \n",
    "        # 5. Classify\n",
    "        logits = self.classifier(fused)\n",
    "        \n",
    "        if return_features:\n",
    "            return logits, engram_emb, pooled, attn_w\n",
    "        return logits\n",
    "\n",
