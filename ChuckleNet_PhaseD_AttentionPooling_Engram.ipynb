    "trainable = sum(p.numel() for p in model.parameters() if p.requires_grad)\n",
    "frozen = total - trainable\n",
    "print(f'Model: {total:,} total | {trainable:,} trainable | {frozen:,} frozen')\n",
    "print(f'Unfrozen layers: last {N_UNFREEZE} WavLM transformer blocks')"
