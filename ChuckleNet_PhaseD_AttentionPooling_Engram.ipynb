    "# 🔟 Training loop with discriminative learning rates\n",
    "\n",
    "# Optimizer: different LR for encoder vs head\n",
    "encoder_params = list(wavlm_encoder.encoder.parameters())\n",
    "head_params = (\n",
    "    list(model.audio_pool.parameters()) +\n",
    "    list(model.engram.parameters()) +\n",
    "    list(model.prosody_proj.parameters()) +\n",
    "    list(model.classifier.parameters())\n",
    ")\n",
    "\n",
    "optimizer = torch.optim.AdamW([\n",
    "    {'params': [p for p in encoder_params if p.requires_grad], 'lr': 5e-5},  # unfrozen WavLM\n",
    "    {'params': head_params, 'lr': 1e-3}\n",
    "])\n",
    "\n",
    "scheduler = torch.optim.lr_scheduler.CosineAnnealingWarmRestarts(optimizer, T_0=5, T_mult=2)\n",
    "\n",
    "# Class weight for imbalance (laughter is ~26% of training data)\n",
    "pos_weight = torch.tensor([1.0, 4.0]).to(device)  # upweight positive class\n",
    "criterion = torch.nn.BCEWithLogitsLoss(pos_weight=pos_weight)\n",
    "from torch.nn import CrossEntropyLoss\n",
    "criterion_cls = CrossEntropyLoss(weight=torch.tensor([1.0, 4.0]).to(device))\n",
    "\n",
    "BATCH = 32\n",
    "EPOCHS = 8\n",
    "best_val_f1 = 0.0\n",
    "history = []\n",
    "\n",
    "def load_audio_segment(sample, pad=True):\n",
    "    try:\n",
    "        va, _ = librosa.load(sample['audio_path'], sr=SR, mono=True,\n",
    "                           offset=max(0, sample['start']-0.05), duration=5.2)\n",
    "    except:\n",
    "        va = np.zeros(MAX_LEN, dtype=np.float32)\n",
    "    if va.shape[0] > MAX_LEN:\n",
    "        va = va[:MAX_LEN]\n",
    "    elif pad:\n",
    "        va = np.pad(va, (0, MAX_LEN - va.shape[0]))\n",
    "    return va\n",
    "\n",
    "print(f'Training Phase D: CSA + Engram + Partial Unfreeze...')\n",
    "print(f'BATCH={BATCH}, EPOCHS={EPOCHS}, LR=encoder:5e-5, head:1e-3')\n",
    "\n",
    "for epoch in range(1, EPOCHS+1):\n",
    "    t0 = time.time()\n",
    "    model.train()\n",
    "    \n",
    "    perm = np.random.permutation(len(train))\n",
    "    NB = len(train) // BATCH\n",
    "    total_loss = 0.0\n",
    "    \n",
    "    tp_pred, tp_label = [], []\n",
    "    \n",
    "    for bi in range(NB):\n",
    "        batch_idx = perm[bi*BATCH:(bi+1)*BATCH]\n",
    "        \n",
    "        # Load audio\n",
    "        audio_batch = np.stack([load_audio_segment(train[i]) for i in batch_idx])\n",
    "        labels = np.array([train[i]['label'] for i in batch_idx])\n",
    "        \n",
    "        # Load prosody\n",
    "        prosody_batch = np.stack([\n",
    "            prosody_dict.get(f\"{train[i]['video_id']}_{train[i]['start']:.2f}\", np.zeros(55))\n",
    "            for i in batch_idx\n",
    "        ])\n",
    "        \n",
    "        x = torch.from_numpy(audio_batch[:, None]).to(device)  # (B, 1, 80000)\n",
    "        y = torch.from_numpy(labels).long().to(device)\n",
    "        p = torch.from_numpy(prosody_batch).float().to(device)\n",
    "        \n",
    "        optimizer.zero_grad()\n",
    "        logits = model(x, p)\n",
    "        loss = criterion_cls(logits, y)\n",
    "        loss.backward()\n",
    "        torch.nn.utils.clip_grad_norm_(model.parameters(), 1.0)\n",
    "        optimizer.step()\n",
    "        \n",
    "        total_loss += loss.item()\n",
    "        tp_pred.extend(logits.argmax(1).cpu().tolist())\n",
    "        tp_label.extend(y.cpu().tolist())\n",
    "        \n",
    "        if (bi+1) % 100 == 0:\n",
    "            gc.collect()\n",
    "    \n",
    "    scheduler.step()\n",
    "    train_loss = total_loss / NB\n",
    "    train_f1 = f1_score(tp_label, tp_pred, zero_division=0)\n",
    "    \n",
    "    # Validation\n",
    "    model.eval()\n",
    "    vp, vl = [], []\n",
    "    val_perm = np.random.permutation(len(val))[:min(1000, len(val))]\n",
    "    \n",
    "    with torch.no_grad():\n",
    "        for vi in val_perm:\n",
    "            vs = val[vi]\n",
    "            va = load_audio_segment(vs)\n",
    "            pf = prosody_dict.get(f\"{vs['video_id']}_{vs['start']:.2f}\", np.zeros(55))\n",
    "            vx = torch.from_numpy(va[None, None]).to(device)\n",
    "            vp_t = torch.from_numpy(pf[None]).float().to(device)\n",
    "            logits = model(vx, vp_t)\n",
    "            vp.append(logits.argmax(1).cpu().item())\n",
