    "# 1️⃣1️⃣ Build aligned feature matrices\n",
    "import tqdm\n",
    "\n",
    "def build_feature_matrix(samples_list, text_embs, audio_embs, prosody_dict, text_idx, audio_idx):\n",
    "    \"\"\"Align all three modalities into (N, feature_dim) arrays.\"\"\"\n",
    "    text_map = {uid: i for i, uid in enumerate(text_idx)}\n",
    "    audio_map = {uid: i for i, uid in enumerate(audio_idx)}\n",
    "    \n",
    "    rows_text, rows_audio, rows_prosody, rows_label, rows_uid = [], [], [], [], []\n",
    "    for s in samples_list:\n",
    "        uid = f'{s[\"video_id\"]}_{s[\"start\"]:.2f}'\n",
    "        t_idx = text_map.get(uid)\n",
    "        a_idx = audio_map.get(uid)\n",
    "        p_feat = prosody_dict.get(uid, {})\n",
    "        if t_idx is not None and a_idx is not None:\n",
    "            rows_text.append(text_embs[t_idx])\n",
    "            rows_audio.append(audio_embs[a_idx])\n",
    "            prosody_vals = [p_feat.get(k, 0.0) for k in sorted(p_feat.keys()) if k != 'uid']\n",
    "            rows_prosody.append(prosody_vals)\n",
    "            rows_label.append(s['label'])\n",
    "            rows_uid.append(uid)\n",
    "    \n",
    "    return (np.array(rows_text), np.array(rows_audio),\n",
    "            np.array(rows_prosody), np.array(rows_label), rows_uid)\n",
    "\n",
    "# Build train and test\n",
    "print('Building feature matrices...')\n",
    "(Xtext_tr, Xaudio_tr, Xpros_tr, y_tr, uid_tr) = build_feature_matrix(\n",
    "    train_samples, text_embs, audio_embs, prosody_dict, text_idx, audio_idx)\n",
    "(Xtext_te, Xaudio_te, Xpros_te, y_te, uid_te) = build_feature_matrix(\n",
    "    test_samples, text_embs, audio_embs, prosody_dict, text_idx, audio_idx)\n",
    "\n",
    "print(f'Train: {Xtext_tr.shape}, Test: {Xtext_te.shape}')\n",
    "print(f'Prosody features: {Xpros_tr.shape[1]}')\n",
    "print(f'Train positive: {y_tr.sum()}/{len(y_tr)} ({100*y_tr.mean():.1f}%)')\n",
    "print(f'Test positive:  {y_te.sum()}/{len(y_te)} ({100*y_te.mean():.1f}%)')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 1️⃣2️⃣ Scale prosody features (text+audio are already projected, leave as-is)\n",
    "scaler = StandardScaler()\n",
    "Xpros_tr_s = scaler.fit_transform(np.nan_to_num(Xpros_tr, 0))\n",
    "Xpros_te_s = scaler.transform(np.nan_to_num(Xpros_te, 0))\n",
    "\n",
    "# Quick baseline: Prosody-only F1\n",
    "from sklearn.linear_model import LogisticRegression\n",
    "lr_pros = LogisticRegression(max_iter=500, random_state=42)\n",
    "lr_pros.fit(Xpros_tr_s, y_tr)\n",
    "probs_pros = lr_pros.predict_proba(Xpros_te_s)[:, 1]\n",
    "for t in [0.3, 0.5, 0.7]:\n",
    "    p = precision_score(y_te, (probs_pros >= t).astype(int))\n",
    "    r = recall_score(y_te, (probs_pros >= t).astype(int))\n",
    "    f = f1_score(y_te, (probs_pros >= t).astype(int))\n",
    "    print(f'Prosody-only t={t:.1f}: P={p:.4f} R={r:.4f} F1={f:.4f}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 1️⃣3️⃣ Fusion model: concat + MLP\n",
    "class FusionModel(torch.nn.Module):\n",
    "    def __init__(self, text_dim=256, audio_dim=256, prosody_dim=None, hidden=128):\n",
    "        super().__init__()\n",
    "        self.prosody_proj = torch.nn.Linear(prosody_dim, 64) if prosody_dim else None\n",
    "        total_dim = text_dim + audio_dim + 64\n",
    "        self.head = torch.nn.Sequential(\n",
    "            torch.nn.Linear(total_dim, hidden),\n",
    "            torch.nn.ReLU(),\n",
    "            torch.nn.Dropout(0.3),\n",
    "            torch.nn.Linear(hidden, hidden//2),\n",
    "            torch.nn.ReLU(),\n",
    "            torch.nn.Dropout(0.2),\n",
    "            torch.nn.Linear(hidden//2, 2)\n",
    "        )\n",
    "    def forward(self, text_emb, audio_emb, prosody_feat):\n",
    "        if self.prosody_proj:\n",
    "            prosody_emb = self.prosody_proj(prosody_feat)\n",
    "        else:\n",
    "            prosody_emb = prosody_feat\n",
    "        fused = torch.cat([text_emb, audio_emb, prosody_emb], dim=1)\n",
    "        return self.head(fused)\n",
    "\n",
    "prosody_dim = Xpros_tr_s.shape[1]\n",
    "model = FusionModel(text_dim=256, audio_dim=256, prosody_dim=prosody_dim, hidden=128)\n",
    "model.to(device)\n",
    "\n",
    "# Optimizer: different LR for different components\n",
    "optimizer = torch.optim.AdamW([\n",
    "    {'params': model.prosody_proj.parameters(), 'lr': 1e-3},\n",
    "    {'params': model.head.parameters(), 'lr': 1e-3},\n",
    "    # WavLM encoder partial unfreeze (already has gradients)\n",
    "    {'params': wavlm_model.encoder.parameters(), 'lr': 5e-5},  # unfrozen layers\n",
    "    {'params': wavlm_model.audio_proj.parameters(), 'lr': 1e-4},\n",
    "])\n",
    "scheduler = torch.optim.lr_scheduler.CosineAnnealingLR(optimizer, T_max=10)\n",
    "criterion = torch.nn.CrossEntropyLoss(\n",
    "    weight=torch.tensor([1.0, 5.0]).to(device)  # class weight for imbalance\n",
    ")\n",
    "print(f'Model params: {sum(p.numel() for p in model.parameters()):,}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 1️⃣4️⃣ Training loop\n",
    "BATCH = 64\n",
    "EPOCHS = 10\n",
    "best_f1 = 0\n",
    "\n",
    "Xtext_tr_t = torch.from_numpy(Xtext_tr).float().to(device)\n",
    "Xaudio_tr_t = torch.from_numpy(Xaudio_tr).float().to(device)\n",
    "Xpros_tr_t = torch.from_numpy(Xpros_tr_s).float().to(device)\n",
    "y_tr_t = torch.from_numpy(y_tr).long().to(device)\n",
    "\n",
    "Xtext_te_t = torch.from_numpy(Xtext_te).float().to(device)\n",
    "Xaudio_te_t = torch.from_numpy(Xaudio_te).float().to(device)\n",
    "Xpros_te_t = torch.from_numpy(Xpros_te_s).float().to(device)\n",
    "y_te_np = y_te\n",
    "\n",
    "n_train = len(y_tr_t)\n",
    "perm = torch.randperm(n_train)\n",
    "\n",
    "for epoch in range(EPOCHS):\n",
    "    model.train()\n",
    "    epoch_loss = 0\n",
    "    perm = torch.randperm(n_train)  # reshuffle each epoch\n",
    "    \n",
    "    for i in range(0, n_train, BATCH):\n",
    "        idx = perm[i:i+BATCH]\n",
    "        text_b = Xtext_tr_t[idx]\n",
    "        audio_b = Xaudio_tr_t[idx]\n",
    "        pros_b = Xpros_tr_t[idx]\n",
    "        label_b = y_tr_t[idx]\n",
    "        \n",
    "        optimizer.zero_grad()\n",
    "        \n",
    "        # Forward: audio through wavlm model, text+prosody through fusion\n",
    "        with torch.set_grad_enabled(True):\n",
    "            audio_emb = wavlm_model(audio_b.unsqueeze(1), return_embeds=True)\n",
    "            logits = model(text_b, audio_emb, pros_b)\n",
    "            loss = criterion(logits, label_b)\n",
    "        \n",
    "        loss.backward()\n",
    "        torch.nn.utils.clip_grad_norm_(model.parameters(), 1.0)\n",
    "        optimizer.step()\n",
    "        epoch_loss += loss.item()\n",
    "    \n",
    "    scheduler.step()\n",
    "    \n",
    "    # Evaluate\n",
    "    model.eval()\n",
    "    with torch.no_grad():\n",
    "        audio_te_emb = wavlm_model(Xaudio_te_t.unsqueeze(1), return_embeds=True)\n",
    "        logits_te = model(Xtext_te_t, audio_te_emb, Xpros_te_t)\n",
    "        probs_te = torch.softmax(logits_te, dim=1)[:, 1].cpu().numpy()\n",
    "    \n",
    "    # Sweep threshold\n",
    "    best_ep_f1 = 0\n",
    "    for t in np.linspace(0.3, 0.8, 20):\n",
    "        f = f1_score(y_te_np, (probs_te >= t).astype(int), zero_division=0)\n",
    "        if f > best_ep_f1:\n",
    "            best_ep_f1 = f\n",
    "            best_t_ep = t\n",
    "    \n",
    "    p = precision_score(y_te_np, (probs_te >= best_t_ep).astype(int), zero_division=0)\n",
    "    r = recall_score(y_te_np, (probs_te >= best_t_ep).astype(int), zero_division=0)\n",
    "    \n",
    "    print(f'Epoch {epoch+1:2d}/{EPOCHS} | loss={epoch_loss/len(range(0,n_train,BATCH)):.4f} '\n",
    "          f'| val_f1={best_ep_f1:.4f} P={p:.4f} R={r:.4f} (t={best_t_ep:.2f})')\n",
    "    \n",
    "    if best_ep_f1 > best_f1:\n",
    "        best_f1 = best_ep_f1\n",
    "        torch.save({\n",
    "            'fusion_state': model.state_dict(),\n",
    "            'wavlm_state': wavlm_model.state_dict(),\n",
    "            'optimizer_state': optimizer.state_dict(),\n",
    "            'epoch': epoch,\n",
    "            'val_f1': best_f1,\n",
    "            'best_threshold': best_t_ep\n",
    "        }, f'{OUTPUT_DIR}/fusion_phaseC_best.pt')\n",
    "        print(f'  ✅ Saved best model (F1={best_f1:.4f})')\n",
    "\n",
    "print(f'\\nBest val F1: {best_f1:.4f}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 1️⃣5️⃣ Final threshold sweep on test set\n",
    "ckpt = torch.load(f'{OUTPUT_DIR}/fusion_phaseC_best.pt', map_location=device)\n",
    "model.load_state_dict(ckpt['fusion_state'])\n",
    "wavlm_model.load_state_dict(ckpt['wavlm_state'])\n",
    "model.eval()\n",
    "\n",
    "with torch.no_grad():\n",
    "    audio_te_emb = wavlm_model(Xaudio_te_t.unsqueeze(1), return_embeds=True)\n",
    "    logits = model(Xtext_te_t, audio_te_emb, Xpros_te_t)\n",
    "    all_probs = torch.softmax(logits, dim=1)[:, 1].cpu().numpy()\n",
    "\n",
    "print(f\"{'Threshold':>10} {'Precision':>10} {'Recall':>10} {'F1':>10} {'TP':>6} {'FP':>6} {'FN':>6}\")\n",
    "print('-' * 70)\n",
    "results = []\n",
    "for t in [0.30, 0.40, 0.50, 0.55, 0.60, 0.65, 0.70, 0.75, 0.80, 0.85, 0.90]:\n",
    "    preds = (all_probs >= t).astype(int)\n",
    "    tp = int(((preds == 1) & (y_te_np == 1)).sum())\n",
    "    fp = int(((preds == 1) & (y_te_np == 0)).sum())\n",
    "    fn = int(((preds == 0) & (y_te_np == 1)).sum())\n",
    "    prec = tp / (tp + fp) if (tp + fp) > 0 else 0\n",
    "    rec = tp / (tp + fn) if (tp + fn) > 0 else 0\n",
    "    f1 = 2 * prec * rec / (prec + rec) if (prec + rec) > 0 else 0\n",
    "    print(f'{t:>10.2f} {prec:>10.4f} {rec:>10.4f} {f1:>10.4f} {tp:>6} {fp:>6} {fn:>6}')\n",
    "    results.append({'threshold': t, 'precision': prec, 'recall': rec, 'f1': f1})\n",
    "\n",
    "best = max(results, key=lambda r: r['f1'])\n",
    "print(f\"\\n✅ BEST: t={best['threshold']:.2f} F1={best['f1']:.4f} P={best['precision']:.4f} R={best['recall']:.4f}\")\n",
    "print(f\"   vs text-only baseline F1=0.8194\")\n",
    "print(f\"   vs audio-only baseline F1=0.6173\")"
   ]
