    "# 4️⃣ Load XLM-R (text branch)\n",
    "print('Loading XLM-R...')\n",
    "xlm_model = XLM_RobertaModel.from_pretrained('FacebookAI/xlm-roberta-base')\",
    "\n",
    "xlm_model.to(device)\n",
    "xlm_model.eval()\n",
    "xlm_tokenizer = XLM_RobertaTokenizer.from_pretrained('FacebookAI/xlm-roberta-base')\n",
