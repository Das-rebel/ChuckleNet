   "source": [
    "# 5️⃣ Load WavLM (audio branch — partial unfreeze last 3 layers)\n",
    "print('Loading WavLM (partial unfreeze)...')\n",
    "encoder = WavLMModel.from_pretrained('microsoft/wavlm-base-plus')\n",
    "encoder.to(device)\n",
    "feature_extractor = Wav2Vec2FeatureExtractor.from_pretrained('microsoft/wavlm-base-plus')\n",
    "\n",
    "# ---- PARTIAL UNFREEZE: last 3 transformer layers ----\n",
    "N_UNFREEZE = 3\n",
    "for param in encoder.parameters():\n",
    "    param.requires_grad = False\n",
    "for layer in list(encoder.encoder.layers)[-N_UNFREEZE:]:\n",
    "    for param in layer.parameters():\n",
    "        param.requires_grad = True\n",
    "\n",
    "class WavLMClassifier(torch.nn.Module):\n",
    "    def __init__(self, enc):\n",
    "        super().__init__()\n",
    "        self.encoder = enc\n",
    "        self.audio_proj = torch.nn.Linear(768, 256)\n",
    "        self.classifier = torch.nn.Sequential(\n",
    "            torch.nn.Linear(512, 128), torch.nn.ReLU(), torch.nn.Dropout(0.3),\n",
    "            torch.nn.Linear(128, 2)\n",
    "        )\n",
    "    def forward(self, waveforms, return_embeds=False):\n",
    "        with torch.no_grad() if not any(p.requires_grad for p in self.encoder.parameters()) else torch.enable_grad():\n",
    "            wav_list = [w.cpu().numpy().squeeze() for w in waveforms]\n",
    "            inputs = feature_extractor(wav_list, sampling_rate=SR, return_tensors='pt', padding=True)\n",
    "            inputs = {k: v.to(waveforms.device) for k, v in inputs.items()}\n",
    "            hidden = self.encoder(**inputs).last_hidden_state.mean(dim=1)\n",
    "        audio_emb = self.audio_proj(hidden)\n",
    "        if return_embeds:\n",
    "            return audio_emb\n",
    "        return audio_emb\n",
    "\n",
    "wavlm_model = WavLMClassifier(encoder).to(device)\n",
    "\n",
    "# Load trained weights (only load classifier+audio_proj weights, encoder is partially frozen)\n",
    "ckpt = torch.load(WAVLM_CKPT, map_location=device)\n",
    "wavlm_model.load_state_dict(ckpt['model_state_dict'], strict=False)\n",
    "wavlm_model.to(device)\n",
    "wavlm_model.train()   # <-- set to TRAIN mode for fine-tuning\n",
    "\n",
    "# Count unfrozen params\n",
    unfrozen = sum(1 for p in wavlm_model.parameters() if p.requires_grad)\n",
    "total = sum(1 for _ in wavlm_model.parameters())\n",
    "print(f'WavLM: {unfrozen}/{total} layers unfrozen')"
   ]
  },
