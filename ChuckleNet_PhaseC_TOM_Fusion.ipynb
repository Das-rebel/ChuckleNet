   "source": [
    "# 6️⃣ Prosody-ToM feature extraction (per utterance)\n",
    "import librosa\n",
    "\n",
    "def extract_prosody(audio_path, start_sec, end_sec):\n",
    "    \"\"\"\n",
    "    Extract Theory-of-Mind prosody features for an utterance.\n",
    "    Based on Purandare 2006, Pickering 2009, Bachorowski 2001.\n",
    "    \n",
    "    Returns a dict of ~52 features.\n",
    "    \"\"\"\n",
    "    try:\n",
    "        y, sr = librosa.load(audio_path, sr=SR, mono=True,\n",
    "                           offset=max(0, start_sec - 0.1),\n",
    "                           duration=(end_sec - start_sec) + 0.2)\n",
    "    except:\n",
    "        y = np.zeros(MAX_LEN, dtype=np.float32)\n",
    "\n",
    "    feats = {}\n",
    "\n",
    "    # ---- PAUSE / SILENCE (ToM #1: Purandare 2006) ----\n",
    "    # Detect silence regions\n",
    "    intervals = librosa.effects.split(y, top_db=30, frame_length=1024, hop_length=512)\n",
    "    if len(intervals) > 0:\n",
    "        pauses = []\n",
    "        for i in range(len(intervals) - 1):\n",
    "            gap = intervals[i+1][0] - intervals[i][1]\n",
    "            gap_sec = gap / sr\n",
    "            pauses.append(gap_sec)\n",
    "        feats['pause_max'] = max(pauses) if pauses else 0.0\n",
    "        feats['pause_mean'] = np.mean(pauses) if pauses else 0.0\n",
    "        feats['pause_count'] = sum(1 for p in pauses if p > 0.1)\n",
    "        feats['pause_density'] = sum(1 for p in pauses if p > 0.1) / max(len(pauses), 1)\n",
    "        feats['pause_total'] = sum(pauses)\n",
    "        # Long pause (>0.8s) = strong ToM signal (Purandare)\n",
    "        feats['long_pause_count'] = sum(1 for p in pauses if p >= 0.8)\n",
    "        feats['has_long_pause'] = float(any(p >= 0.8 for p in pauses))\n",
    "    else:\n",
    "        for k in ['pause_max','pause_mean','pause_count','pause_density',\n",
    "                  'pause_total','long_pause_count','has_long_pause']:\n",
    "            feats[k] = 0.0\n",
    "\n",
    "    # ---- F0 / PITCH (Duchenne marker) ----\n",
    "    try:\n",
    "        f0, voiced, _ = librosa.pyin(y, fmin=75, fmax=500, sr=sr,\n",
    "                                      frame_length=2048, hop_length=512)\n",
    "        f0_clean = f0[~np.isnan(f0)]\n",
    "        if len(f0_clean) > 5:\n",
    "            feats['f0_mean'] = float(np.mean(f0_clean))\n",
    "            feats['f0_std'] = float(np.std(f0_clean))\n",
    "            feats['f0_range'] = float(np.max(f0_clean) - np.min(f0_clean))\n",
    "            feats['f0_max'] = float(np.max(f0_clean))\n",
    "            feats['f0_min'] = float(np.min(f0_clean))\n",
    "            # F0 variability = Duchenne genuineness marker\n",
    "            feats['f0_variability'] = feats['f0_std'] / max(feats['f0_mean'], 1)\n",
    "            # F0 slope (delivery momentum)\n",
    "            feats['f0_slope'] = float(np.polyfit(range(len(f0_clean)), f0_clean, 1)[0])\n",
    "        else:\n",
    "            for k in ['f0_mean','f0_std','f0_range','f0_max','f0_min','f0_variability','f0_slope']:\n",
    "                feats[k] = 0.0\n",
    "    except:\n",
    "        for k in ['f0_mean','f0_std','f0_range','f0_max','f0_min','f0_variability','f0_slope']:\n",
    "            feats[k] = 0.0\n",
    "\n",
    "    # ---- ENERGY / RMS ----\n",
    "    rms = librosa.feature.rms(y=y, frame_length=2048, hop_length=512)[0]\n",
    "    feats['rms_mean'] = float(np.mean(rms))\n",
    "    feats['rms_std'] = float(np.std(rms))\n",
    "    feats['rms_max'] = float(np.max(rms))\n",
    "    feats['rms_range'] = float(np.max(rms) - np.min(rms))\n",
    "    # Energy spikes = audience laughter or emphatic delivery\n",
    "    feats['energy_spike_count'] = sum(1 for r in rms if r > np.mean(rms) + 2*np.std(rms))\n",
    "\n",
    "    # ---- SPEECH RATE (word duration proxy) ----\n",
    "    n_words = max(1, len([w for w in y if np.abs(w) > 0.01]))\n",
    "    dur = end_sec - start_sec\n",
    "    feats['speech_rate'] = n_words / max(dur, 0.1)\n",
    "    feats['utterance_duration'] = dur\n",
    "\n",
    "    # ---- SPECTRAL (Duchenne voice quality) ----\n",
    "    S = np.abs(librosa.stft(y))\n",
    "    spec_bw = librosa.feature.spectral_bandwidth(y=y, sr=sr)[0]\n",
    "    feats['spectral_centroid_mean'] = float(np.mean(librosa.feature.spectral_centroid(y=y, sr=sr)[0]))\n",
    "    feats['spectral_bandwidth_mean'] = float(np.mean(spec_bw))\n",
    "\n",
    "    # MFCCs (13 standard)\n",
    "    mfccs = librosa.feature.mfcc(y=y, sr=sr, n_mfcc=13)\n",
    "    for i in range(13):\n",
    "        feats[f'mfcc{i+1}_mean'] = float(np.mean(mfccs[i]))\n",
    "\n",
    "    return feats\n",
    "\n",
    "# Test extraction\n",
    "test_feats = extract_prosody(\n",
    "    f'{AUDIO_DIR}/YntBaJ8FiK0.mp3',\n",
    "    start_sec=1490.86, end_sec=1494.28\n",
    ")\n",
    "print(f'Extracted {len(test_feats)} prosody features')\n",
    "print([k for k in test_feats.keys() if 'pause' in k or 'f0' in k][:10])"
   ]
  },
