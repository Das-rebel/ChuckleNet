# API Keys for Growth Workflow OS
# Copy this to .env and fill in your actual keys

MISTRAL_API_KEY=your_mistral_key_here
GROQ_API_KEY=your_groq_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
MINIMAX_API_KEY=your_minimax_key_here
ZAI_API_KEY=your_zai_key_here
CEREBRAS_API_KEY=your_cerebras_key_here

# Reddit cookies (from Brave browser) — see REDDIT_API_SETUP.md
REDDIT_SESSION=your_reddit_session_cookie
REDDIT_TOKEN_V2=your_reddit_token_v2
REDDIT_CSRF_TOKEN=your_csrf_token
REDDIT_EDGECOOKIE=your_edgebucket
REDDIT_LOID=your_loid
REDDIT_USER=your_reddit_username
